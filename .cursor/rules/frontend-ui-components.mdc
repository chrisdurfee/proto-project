## Lists

```javascript
import { ScrollableList, List, DataList, DynamicList } from "@base-framework/organisms";
import { ScrollableDataTable, DynamicDataTable, CheckboxCol, HeaderCol } from "@base-framework/ui/organisms";

// ScrollableList — paginated, scroll-driven loading
ScrollableList({
    data: new VehicleModel({ filter: { type: 'sedan' } }),
    cache: 'listName',
    key: 'id',
    xhrMethod: 'all', // defaults to 'all'
    skeleton: { number: 4, row: BookmarkRowSkeleton },
    rowItem: BookmarkCard,
    emptyState: () => BookmarkEmptyState()
})

// ScrollableDataTable — paginated table
ScrollableDataTable({
    data,
    cache: 'list',
    limit: 50,
    customHeader: HeaderRow(),
    skeleton: true,
    rowItem: FollowingRow,
    key: 'id',
    emptyState: () => EmptyState({ title: 'No Data', description: 'Nothing here', icon: 'favorite' })
})
```

**Table Header/Rows**:
```javascript
const HeaderRow = () =>
    Thead([Tr({ class: 'text-muted-foreground border-b' }, [
        CheckboxCol({ class: 'hidden md:table-cell' }),
        HeaderCol({ key: 'user', label: 'User' }),
        HeaderCol({ key: 'email', label: 'Email', class: 'hidden md:table-cell' }),
    ])]);

export const DataRow = (row, onSelect) =>
    Tr({ class: 'items-center px-4 py-2 hover:bg-muted/50' }, [
        Td({ class: 'p-4 hidden md:table-cell' }, [
            new Checkbox({ checked: row.selected, onChange: () => onSelect(row) })
        ]),
        Td({ class: 'p-4' }, [UserAvatar(row)]),
    ]);
```

